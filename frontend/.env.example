# Frontend Environment Configuration Template
# Copy this file to .env.development, .env.staging, or .env.production
# and update the values for your environment

# API Configuration
REACT_APP_API_ENDPOINT=http://localhost:3001
REACT_APP_API_TIMEOUT=30000

# Environment
REACT_APP_ENVIRONMENT=development

# Logging
REACT_APP_LOG_LEVEL=debug

# Feature Flags
REACT_APP_ENABLE_MOCK_DATA=false
REACT_APP_ENABLE_ANALYTICS=false

# AWS Configuration
REACT_APP_BEDROCK_REGION=ap-south-1
REACT_APP_AWS_REGION=ap-south-1

# Caching
REACT_APP_CACHE_TTL=300000

# CloudFront Configuration (populated by deployment script)
REACT_APP_CLOUDFRONT_DOMAIN=
REACT_APP_DISTRIBUTION_ID=

# Error Tracking (optional)
REACT_APP_SENTRY_DSN=

# Performance Monitoring (optional)
REACT_APP_ENABLE_PERFORMANCE_MONITORING=false

# Build Configuration
GENERATE_SOURCEMAP=true
SKIP_PREFLIGHT_CHECK=false
