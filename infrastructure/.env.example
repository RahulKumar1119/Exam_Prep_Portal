# Infrastructure Environment Configuration Template
# Copy this file to .env and update the values for your environment

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012

# Project Configuration
PROJECT_NAME=jaiib-caiib-exam-prep-portal
ENVIRONMENT=staging

# Amplify Configuration
AMPLIFY_APP_NAME=jaiib-caiib-exam-prep-portal-staging
AMPLIFY_BRANCH=staging
AMPLIFY_APP_ID=

# CloudFront Configuration
CLOUDFRONT_PRICE_CLASS=PriceClass_100
CLOUDFRONT_ENABLE_LOGGING=true
CLOUDFRONT_LOG_RETENTION_DAYS=90

# S3 Configuration
S3_LOGS_BUCKET=jaiib-caiib-cloudfront-logs-staging
S3_ARTIFACTS_BUCKET=jaiib-caiib-frontend-artifacts-staging
S3_ENABLE_VERSIONING=true
S3_BLOCK_PUBLIC_ACCESS=true

# IAM Configuration
IAM_ROLE_NAME=jaiib-caiib-amplify-role-staging
IAM_POLICY_NAME=jaiib-caiib-amplify-policy-staging

# Domain Configuration (optional)
CUSTOM_DOMAIN=
CERTIFICATE_ARN=

# Monitoring Configuration
ENABLE_CLOUDWATCH_ALARMS=true
SNS_TOPIC_ARN=

# Build Configuration
BUILD_TIMEOUT_MINUTES=30
BUILD_CACHE_ENABLED=true

# Deployment Configuration
ENABLE_AUTO_DEPLOYMENT=true
DEPLOYMENT_STRATEGY=blue-green
